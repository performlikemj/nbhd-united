FROM node:22-bookworm-slim

# Keep in sync with OPENCLAW_CURRENT_VERSION in apps/orchestrator/tool_policy.py
ARG OPENCLAW_VERSION=2026.5.7
# Pinned for Phase 1 BYO Anthropic CLI subscription. Binary is dormant
# until a tenant with byo_models_enabled=True connects via /settings/ai-provider.
ARG CLAUDE_CODE_VERSION=2.1.123

ENV NODE_ENV=production
# --dns-result-order=ipv4first: Azure Container Apps has unreliable IPv6 to
# external APIs. Node 22's autoSelectFamily=true tries IPv6 first, causing
# Telegram setWebhook to fail and trigger crash-loop auto-restarts.
# NOTE: --require for suppress-chmod-eperm.js is added AFTER the COPY step
# below (npm install reads NODE_OPTIONS and would fail if the file isn't
# present yet).
ENV NODE_OPTIONS="--max-old-space-size=512 --dns-result-order=ipv4first --no-network-family-autoselection"

RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates bsdmainutils \
    && rm -rf /var/lib/apt/lists/*
# bsdmainutils provides `script(1)`, used by entrypoint.sh to fake a TTY
# around `openclaw models auth login` (its CLI handler hard-checks
# `process.stdin.isTTY` — see `auth-BQuNQ6PP.js:362`).

RUN npm install --global \
        "openclaw@${OPENCLAW_VERSION}" \
        "@openclaw/line@${OPENCLAW_VERSION}" \
        "@googleworkspace/cli" \
        "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
    && npm cache clean --force
# OpenClaw 5.2 externalized the LINE channel plugin out of core. Pin
# @openclaw/line to the same OPENCLAW_VERSION so the manifest's
# minHostVersion check passes (see dist/manifest-registry-*.js).
# Telegram, memory-core, openrouter, anthropic remain bundled in core.

WORKDIR /opt/nbhd

COPY runtime/openclaw/plugins/nbhd-google-tools /opt/nbhd/plugins/nbhd-google-tools
COPY runtime/openclaw/plugins/nbhd-journal-tools /opt/nbhd/plugins/nbhd-journal-tools
COPY runtime/openclaw/plugins/nbhd-usage-reporter /opt/nbhd/plugins/nbhd-usage-reporter
COPY runtime/openclaw/plugins/nbhd-image-gen /opt/nbhd/plugins/nbhd-image-gen
COPY runtime/openclaw/plugins/nbhd-reddit-tools /opt/nbhd/plugins/nbhd-reddit-tools
COPY runtime/openclaw/plugins/nbhd-finance-tools /opt/nbhd/plugins/nbhd-finance-tools
COPY runtime/openclaw/plugins/nbhd-fuel-tools /opt/nbhd/plugins/nbhd-fuel-tools
COPY runtime/openclaw/plugins/nbhd-insights-tools /opt/nbhd/plugins/nbhd-insights-tools
COPY runtime/openclaw/plugins/nbhd-settings-tools /opt/nbhd/plugins/nbhd-settings-tools
COPY skills/gws-* /opt/nbhd/skills/
COPY agent-skills /opt/nbhd/agent-skills
COPY templates/openclaw /opt/nbhd/templates/openclaw
COPY runtime/openclaw/proxy.js /opt/nbhd/proxy.js
COPY runtime/openclaw/suppress-chmod-eperm.js /opt/nbhd/suppress-chmod-eperm.js
COPY runtime/openclaw/redact-stdout.js /opt/nbhd/redact-stdout.js
COPY runtime/openclaw/tool-logger.js /opt/nbhd/tool-logger.js
COPY runtime/openclaw/claude-with-token.sh /opt/nbhd/claude-with-token.sh
COPY runtime/openclaw/claude-settings.json /opt/nbhd/claude-settings.json
COPY runtime/openclaw/entrypoint.sh /usr/local/bin/nbhd-openclaw-entrypoint

RUN chmod +x /usr/local/bin/nbhd-openclaw-entrypoint /opt/nbhd/claude-with-token.sh \
    && chown -R node:node /opt/nbhd /usr/local/bin/nbhd-openclaw-entrypoint

USER node

# --require: load shims before OpenClaw starts.
#   1. suppress-chmod-eperm.js — chmod EPERM/EACCES suppression. Two
#      layers: fs.chmodSync monkey-patch (handles 2026.5.7+ sync throws;
#      essential for cron firing) AND legacy plugin-SDK unhandledRejection
#      handler. See runtime/openclaw/suppress-chmod-eperm.js for full why.
#   2. redact-stdout.js — tenant-content redaction on stdout/stderr.
#      Required because openclaw@2026.5.7's gateway fast path skips
#      enableConsoleCapture(), so console writes hit the streams un-
#      redacted. Wraps process.{stdout,stderr}.write to mask known JSON
#      content shapes (raw_params, "message":"...") and drop non-
#      operational prose lines. See runtime/openclaw/redact-stdout.js.
ENV NODE_OPTIONS="${NODE_OPTIONS} --require /opt/nbhd/suppress-chmod-eperm.js --require /opt/nbhd/redact-stdout.js"

# Disable mDNS/bonjour — useless on Azure Container Apps (containers are
# accessed via FQDN, not local network discovery) and causes intermittent
# CIAO ANNOUNCEMENT CANCELLED crashes on startup.
ENV OPENCLAW_DISABLE_BONJOUR=1

ENV OPENCLAW_GOOGLE_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-google-tools
ENV OPENCLAW_USAGE_PLUGIN_ID=nbhd-usage-reporter
ENV OPENCLAW_USAGE_REPORTER_PLUGIN_ID=
ENV OPENCLAW_JOURNAL_PLUGIN_ID=nbhd-journal-tools
ENV OPENCLAW_USAGE_REPORTER_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-usage-reporter
ENV OPENCLAW_JOURNAL_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-journal-tools
ENV OPENCLAW_IMAGE_GEN_PLUGIN_ID=nbhd-image-gen
ENV OPENCLAW_IMAGE_GEN_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-image-gen

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/nbhd-openclaw-entrypoint"]

