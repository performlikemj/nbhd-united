FROM node:22-bookworm-slim

ARG OPENCLAW_VERSION=2026.4.5

ENV NODE_ENV=production
# --dns-result-order=ipv4first: Azure Container Apps has unreliable IPv6 to
# external APIs. Node 22's autoSelectFamily=true tries IPv6 first, causing
# Telegram setWebhook to fail and trigger crash-loop auto-restarts.
# NOTE: --require for suppress-chmod-eperm.js is added AFTER the COPY step
# below (npm install reads NODE_OPTIONS and would fail if the file isn't
# present yet).
ENV NODE_OPTIONS="--max-old-space-size=512 --dns-result-order=ipv4first --no-network-family-autoselection"

RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN npm install --global "openclaw@${OPENCLAW_VERSION}" "@googleworkspace/cli" \
    && npm cache clean --force

WORKDIR /opt/nbhd

COPY runtime/openclaw/plugins/nbhd-google-tools /opt/nbhd/plugins/nbhd-google-tools
COPY runtime/openclaw/plugins/nbhd-journal-tools /opt/nbhd/plugins/nbhd-journal-tools
COPY runtime/openclaw/plugins/nbhd-usage-reporter /opt/nbhd/plugins/nbhd-usage-reporter
COPY runtime/openclaw/plugins/nbhd-image-gen /opt/nbhd/plugins/nbhd-image-gen
COPY runtime/openclaw/plugins/nbhd-reddit-tools /opt/nbhd/plugins/nbhd-reddit-tools
COPY runtime/openclaw/plugins/nbhd-finance-tools /opt/nbhd/plugins/nbhd-finance-tools
COPY runtime/openclaw/plugins/nbhd-fuel-tools /opt/nbhd/plugins/nbhd-fuel-tools
COPY skills/gws-* /opt/nbhd/skills/
COPY agent-skills /opt/nbhd/agent-skills
COPY templates/openclaw /opt/nbhd/templates/openclaw
COPY runtime/openclaw/proxy.js /opt/nbhd/proxy.js
COPY runtime/openclaw/suppress-chmod-eperm.js /opt/nbhd/suppress-chmod-eperm.js
COPY runtime/openclaw/entrypoint.sh /usr/local/bin/nbhd-openclaw-entrypoint

RUN chmod +x /usr/local/bin/nbhd-openclaw-entrypoint \
    && chown -R node:node /opt/nbhd /usr/local/bin/nbhd-openclaw-entrypoint

USER node

# --require: load chmod EPERM handler before OpenClaw starts. Uses OpenClaw's
# public plugin SDK API (registerUnhandledRejectionHandler) to suppress the
# crash. See runtime/openclaw/suppress-chmod-eperm.js.
ENV NODE_OPTIONS="${NODE_OPTIONS} --require /opt/nbhd/suppress-chmod-eperm.js"

# Disable mDNS/bonjour — useless on Azure Container Apps (containers are
# accessed via FQDN, not local network discovery) and causes intermittent
# CIAO ANNOUNCEMENT CANCELLED crashes on startup.
ENV OPENCLAW_DISABLE_BONJOUR=1

ENV OPENCLAW_GOOGLE_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-google-tools
ENV OPENCLAW_USAGE_PLUGIN_ID=nbhd-usage-reporter
ENV OPENCLAW_USAGE_REPORTER_PLUGIN_ID=
ENV OPENCLAW_JOURNAL_PLUGIN_ID=nbhd-journal-tools
ENV OPENCLAW_USAGE_REPORTER_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-usage-reporter
ENV OPENCLAW_JOURNAL_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-journal-tools
ENV OPENCLAW_IMAGE_GEN_PLUGIN_ID=nbhd-image-gen
ENV OPENCLAW_IMAGE_GEN_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-image-gen

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/nbhd-openclaw-entrypoint"]

