# PII redaction (outgoing LLM traffic)
presidio-analyzer>=2.2    # Pattern recognizers only (credit card Luhn, IBAN checksum)
# Neural PII detection: lakshyakh93/deberta_finetuned_pii loaded via
# vanilla PyTorch CPU. We deliberately do NOT route through
# `optimum.onnxruntime`: the prior INT8-quantized ONNX path produced
# different detection output on Linux x86 (prod) than on macOS dev
# machines, AND the optimum / transformers ABI churn broke imports
# outright between 2026-05-07 and the model swap (#695). Vanilla
# PyTorch CPU inference is deterministic across both platforms and
# frees us from the optimum dependency triangle entirely.
# transformers needs an explicit torch (or TF/JAX) backend; we use the
# PyTorch path for AutoModelForTokenClassification. Pin to CPU-only torch
# via the `torch` package — production images don't have CUDA.
torch>=2.0,<3.0
