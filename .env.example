# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (app runtime — uses app_user role, RLS enforced)
DATABASE_URL=postgres://nbhd:nbhd@localhost:5432/nbhd_united
# Admin database (migrations/management commands — uses postgres role, bypasses RLS)
# In production: postgres://postgres:<password>@<host>:5432/postgres
# Run migrations with: DATABASE_URL=$ADMIN_DATABASE_URL python manage.py migrate
ADMIN_DATABASE_URL=postgres://nbhd:nbhd@localhost:5432/nbhd_united

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT
JWT_SECRET=change-me-jwt-secret

# Telegram (shared bot for all tenants)
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Required and must be non-empty; webhook requests are rejected if unset.
TELEGRAM_WEBHOOK_SECRET=random-webhook-secret
# Shared key for internal OpenClaw -> Django runtime calls.
NBHD_INTERNAL_API_KEY=change-me-internal-key

# Stripe (dj-stripe)
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_LIVE_MODE=False
DJSTRIPE_WEBHOOK_SECRET=whsec_...
# Subscription price for the single "starter" tier (read by settings.STRIPE_PRICE_ID).
# Must be a price from the SAME Stripe account as the secret key + webhook secret above.
STRIPE_PRICE_STARTER=price_...

# Frontend/backend URLs
FRONTEND_URL=http://localhost:3000
USAGE_DASHBOARD_SUBSCRIPTION_PRICE=12.0
API_BASE_URL=http://localhost:8000

# Anthropic API (shared key — all OpenClaw instances use this)
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI API key for Whisper/transcription (shared key for all OpenClaw instances)
OPENAI_API_KEY=sk-proj-...
OPENCLAW_GOOGLE_PLUGIN_ID=
OPENCLAW_GOOGLE_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-google-tools
OPENCLAW_JOURNAL_PLUGIN_ID=nbhd-journal-tools
OPENCLAW_JOURNAL_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-journal-tools
OPENCLAW_USAGE_PLUGIN_ID=nbhd-usage-reporter
OPENCLAW_USAGE_REPORTER_PLUGIN_PATH=/opt/nbhd/plugins/nbhd-usage-reporter
OPENCLAW_USAGE_REPORTER_PLUGIN_ID=
OPENCLAW_CONTAINER_SECRET_BACKEND=keyvault
AZURE_KV_SECRET_ANTHROPIC_API_KEY=anthropic-api-key
AZURE_KV_SECRET_OPENAI_API_KEY=openai-api-key
AZURE_KV_SECRET_TELEGRAM_BOT_TOKEN=telegram-bot-token
AZURE_KV_SECRET_NBHD_INTERNAL_API_KEY=nbhd-internal-api-key

# Azure
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-nbhd-prod
AZURE_LOCATION=eastus
AZURE_CONTAINER_ENV_ID=/subscriptions/.../managedEnvironments/...
AZURE_ACR_SERVER=nbhdunited.azurecr.io
AZURE_KEY_VAULT_NAME=kv-nbhd-prod
AZURE_STORAGE_ACCOUNT_NAME=stnbhdprod

# Set to true for local dev without Azure
AZURE_MOCK=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Sentry (error + log + performance monitoring). Leave SENTRY_DSN empty to
# disable entirely — the SDK only initializes when a DSN is present (and never
# during a test run), so local dev and CI don't send events. In production set
# SENTRY_DSN on the Container App (from Key Vault) to turn it on.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Forward Python logging to Sentry's Logs stream (the "check logs" surface).
SENTRY_ENABLE_LOGS=true
# Minimum level sent to the Logs stream. WARNING (default) skips per-request INFO
# chatter so it doesn't flood Sentry. Use ERROR for errors-only, INFO for all.
SENTRY_LOGS_LEVEL=WARNING
# PII off by default — keeps request bodies, emails, IPs, cookies out of Sentry,
# matching the platform's privacy model. Only set true as a deliberate decision.
SENTRY_SEND_DEFAULT_PII=false
# Tracing + profiling sample rates (0.0–1.0). 1.0 = capture everything; lower
# (e.g. 0.1) in production as traffic grows. No redeploy needed to change.
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
SENTRY_PROFILE_LIFECYCLE=trace
# Optional: deploy identifier (e.g. the Django image SHA) to tag events with.
SENTRY_RELEASE=
