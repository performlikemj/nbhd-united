{
  "routes": [
    {
      "route": "/_next/static/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/images/*",
      "headers": {
        "cache-control": "public, max-age=604800"
      }
    },
    {
      "route": "/icons/*",
      "headers": {
        "cache-control": "public, max-age=604800"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/_next/*",
      "/assets/*",
      "/icons/*",
      "/images/*",
      "/*.css",
      "/*.js",
      "/*.map",
      "/*.json",
      "/*.ico",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.svg",
      "/favicon.ico",
      "/robots.txt"
    ]
  }
}
